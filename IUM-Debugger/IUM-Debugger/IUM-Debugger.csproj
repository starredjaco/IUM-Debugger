<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\SharpDisasm\SharpDisasm\SharpDisasm.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>IUM_Debugger</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
<AllowUnsafeBlocks>true</AllowUnsafeBlocks>

	  <ApplicationManifest>app.manifest</ApplicationManifest>
	  <RuntimeIdentifier>win-x64</RuntimeIdentifier>
	  <PublishSingleFile>true</PublishSingleFile>
	  <SelfContained>true</SelfContained>
	  <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
	  <DebugType>embedded</DebugType>

  </PropertyGroup>
	<Target Name="PublishAfterBuild" AfterTargets="Build" Condition="'$(IsPublishing)' != 'true'">
		<MSBuild Projects="$(MSBuildProjectFullPath)"
				 Targets="Publish"
				 Properties="IsPublishing=true;Configuration=$(Configuration);RuntimeIdentifier=win-x64" />
	</Target>
</Project>
